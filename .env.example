# ── App ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase (server-only; service role key NEVER ships to the client) ─
# Leave blank to run from the local seed (data/accounts/*) — app works out of the box.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── HubSpot CRM v3 (server-only Private App token) ────────────────────
# Leave blank to skip CRM sync (lead still stored locally / in Supabase).
# Maps to standard contact fields only (email, jobtitle, company, name); full
# report context is attached as a timeline Note. Required Private App scopes:
#   crm.objects.contacts.read, crm.objects.contacts.write, crm.objects.notes.write
HUBSPOT_PRIVATE_APP_TOKEN=

# ── PostHog (client analytics) ───────────────────────────────────────
# Leave blank to disable analytics.
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
